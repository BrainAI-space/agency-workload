# Fixed local targets. The bootstrap refuses different values.
AW_POSTGRES_CONTAINER=project-postgres
AW_POSTGRES_SUPERUSER=myuser
AW_POSTGRES_MAINTENANCE_DB=mydb
AW_POSTGRES_HOST_PORT=5434
AW_DATABASE_NAME=agency_workload

# Exact local origins. Wildcards and extra paths are rejected.
APP_ORIGIN=http://localhost:3100
API_ORIGIN=http://localhost:4100
GOTRUE_ORIGIN=http://127.0.0.1:9999
MAILPIT_ORIGIN=http://127.0.0.1:8025
APP_ENV=development
BOOTSTRAP_EMAIL=owner@agency-workload.local
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=auth@agency-workload.local
SMTP_SENDER_NAME=Agency Workload

# Development-only values generated by: npm run local:bootstrap
DATABASE_URL=postgresql://agency_workload_runtime:GENERATED_BY_LOCAL_BOOTSTRAP@127.0.0.1:5434/agency_workload
MIGRATION_DATABASE_URL=postgresql://agency_workload_migrator:GENERATED_BY_LOCAL_BOOTSTRAP@127.0.0.1:5434/agency_workload
GOTRUE_DATABASE_URL=postgresql://supabase_auth_admin:GENERATED_BY_LOCAL_BOOTSTRAP@host.docker.internal:5434/agency_workload
BACKUP_DATABASE_URL=postgresql://agency_workload_backup:GENERATED_BY_LOCAL_BOOTSTRAP@127.0.0.1:5434/agency_workload

GOTRUE_JWT_SECRET=GENERATED_BY_LOCAL_BOOTSTRAP
GOTRUE_SERVICE_ROLE_KEY=GENERATED_BY_LOCAL_BOOTSTRAP
PENDING_AUTH_KEY=GENERATED_BY_LOCAL_BOOTSTRAP
SESSION_SECRET=GENERATED_BY_LOCAL_BOOTSTRAP
