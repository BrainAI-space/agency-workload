{
  "name": "agency-workload",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source resource and capacity planning for agencies and service teams.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24.0.0 <27",
    "npm": ">=11.0.0"
  },
  "packageManager": "npm@11.13.0",
  "overrides": {
    "postcss": "8.5.19"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "node --env-file=.env --import tsx apps/api/src/server.ts",
    "dev:web": "node tools/dev-web.mjs",
    "check": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "test": "npm run test:tools && npm run test --workspaces --if-present",
    "test:tools": "node --test tools/test/config.test.mjs tools/test/bootstrap-local.test.mjs tools/test/redact.test.mjs tools/test/dev-scripts.test.mjs",
    "test:bootstrap:integration": "node tools/test/bootstrap.integration.mjs --integration",
    "test:db:integration": "node --env-file=.env tools/run-db-integration.mjs",
    "test:auth:integration": "node --env-file=.env tools/run-auth-integration.mjs",
    "test:browser:smoke": "node tools/run-browser-smoke.mjs",
    "test:admin:integration": "node --env-file=.env tools/run-admin-integration.mjs",
    "test:planning:integration": "node --env-file=.env tools/run-planning-integration.mjs",
    "test:extended:integration": "node --env-file=.env tools/run-extended-integration.mjs",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "public:sync": "node tools/sync-public.mjs",
    "public:verify": "node tools/verify-public.mjs",
    "config:check": "node tools/verify-config.mjs --template .env.example",
    "config:check:runtime": "node tools/verify-config.mjs --runtime .env",
    "local:bootstrap": "node tools/bootstrap-local.mjs",
    "local:rotate-secrets": "node tools/bootstrap-local.mjs --rotate-secrets",
    "auth:up": "docker compose --project-name agency-workload --env-file .env -f infra/compose.dev.yml up -d --wait",
    "auth:down": "docker compose --project-name agency-workload --env-file .env -f infra/compose.dev.yml down",
    "auth:logs": "node tools/auth-logs.mjs",
    "auth:health": "node tools/check-local-services.mjs",
    "security:check:local": "node tools/verify-secret-safety.mjs",
    "db:migrate": "node --env-file=.env --import tsx packages/db/src/cli.ts",
    "auth:bootstrap-owner": "node --env-file=.env --import tsx apps/api/src/bootstrap-owner.ts",
    "verify:workspaces": "node tools/verify-workspaces.mjs",
    "verify": "npm run verify:workspaces && npm run config:check && npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build && npm audit --audit-level=moderate"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "fast-check": "4.9.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
